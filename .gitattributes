# =============================================================================
# GitHub Linguist Configuration - AgriGuard-RES
# Goal: Make SystemVerilog dominant + suppress vendor firmware noise
# =============================================================================

# --- Force SystemVerilog recognition ---
*.sv  linguist-language=SystemVerilog
*.svh linguist-language=SystemVerilog

# --- Strongly suppress vendor / generated C code ---
**/Drivers/**                    linguist-vendored=true
**/Middlewares/**                linguist-vendored=true
**/Core/**                       linguist-vendored=true
**/Debug/**                      linguist-generated=true
**/Release/**                    linguist-generated=true
**/build/**                      linguist-generated=true

# Specific STM32 noise
**/*_hal_*                       linguist-vendored=true
**/stm32h7xx_*                   linguist-vendored=true
**/system_stm32h7xx.c            linguist-vendored=true
**/stm32h7xx_it.c                linguist-vendored=true

# IDE / STM32CubeIDE artifacts
*.ioc      linguist-generated=true
*.mxproject linguist-generated=true
*.cproject linguist-generated=true
*.project  linguist-generated=true
*.ld       linguist-generated=true

# Documentation
*.pdf      linguist-documentation=true
*.md       linguist-documentation=false
README.md  linguist-documentation=false

# FPGA / HDL priority
HDL_FPGA/**  linguist-language=SystemVerilog
