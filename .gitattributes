# ==============================================================================
# GITHUB LINGUIST CONFIGURATION
# Objective: Suppress vendor/generated C code to highlight SystemVerilog (RTL)
# ==============================================================================

# --- 1. Specific Folder Suppressions (Fixed Paths) ---
Firmware_MCU/AgriGuard_RES/Drivers/** linguist-vendored=true
Firmware_MCU/AgriGuard_RES/Middlewares/** linguist-vendored=true

# --- 2. Global Catch-Alls (Bulletproof backup for HAL/CMSIS files) ---
**/Drivers/CMSIS/** linguist-vendored=true
**/Drivers/STM32H7xx_HAL_Driver/** linguist-vendored=true
**/*_hal_* linguist-vendored=true
**/stm32h7xx_it.c linguist-vendored=true
**/system_stm32h7xx.c linguist-vendored=true

# --- 3. IDE Config & Build Artifacts Suppression ---
Firmware_MCU/AgriGuard_RES/Debug/** linguist-generated=true
Firmware_MCU/AgriGuard_RES/Release/** linguist-generated=true
Firmware_MCU/AgriGuard_RES/build/** linguist-generated=true
*.cproject linguist-generated=true
*.project linguist-generated=true
*.mxproject linguist-generated=true
*.ioc linguist-generated=true
*.ld linguist-generated=true

# --- 4. Documentation & Non-Code Suppression ---
*.pdf linguist-documentation=true
*.log linguist-documentation=true

# --- 5. Force SystemVerilog Prominence ---
*.sv linguist-language=SystemVerilog
*.sv linguist-detectable=true
*.sv linguist-documentation=false
